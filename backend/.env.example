# Hot Monitor 配置文件
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=Hot Monitor
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/hot_monitor.db

# OpenRouter AI 配置 (必填)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# 邮件通知配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
NOTIFICATION_EMAIL=receive_notifications@example.com

# Web Push 配置 (可选)
# 生成 VAPID 密钥: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=your_email@example.com

# 爬虫配置
CRAWL_INTERVAL_MINUTES=5
HOTSPOT_INTERVAL_MINUTES=30
REQUEST_TIMEOUT=30

# 代理配置 (可选，用于访问国外网站)
HTTP_PROXY=
